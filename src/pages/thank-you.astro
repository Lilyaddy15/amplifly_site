---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="You're on the list" description="Thanks for joining the Amplifly waitlist.">
  <section class="min-h-screen flex items-center justify-center bg-deep-navy text-white py-20 pt-32">
    <div class="container px-6 mx-auto text-center max-w-xl">
      <div class="text-6xl mb-6">🎉</div>
      <h1 class="text-white text-4xl font-bold mb-4">You're on the list.</h1>
      <p class="text-medium-blue text-lg leading-relaxed mb-8">
        Thanks for joining the Amplifly waitlist. We'll reach out as soon as early access opens.
      </p>
      <p class="text-medium-blue/60 text-sm mb-10">
        In the meantime, if you have questions or want to share your ND experience to help shape
        the app, email us at{' '}
        <a href="mailto:hello@amplifly.me" class="text-bright-blue hover:underline">hello@amplifly.me</a>.
      </p>
      <a href="/"
         class="inline-block bg-bright-blue hover:bg-bright-blue/80 text-white font-semibold px-8 py-4 rounded-xl transition-colors">
        Back to Amplifly
      </a>
    </div>
  </section>
  <Footer />
</Layout>
