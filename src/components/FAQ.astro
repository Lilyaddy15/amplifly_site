---
const faqs = [
  {
    q: 'Does this require any hardware — Oura Ring, wearable, anything?',
    a: 'No. Amplifly is a pure software app. You check in by tapping one of five brain states each morning. No sensors, no wearables, no subscriptions to other services.',
  },
  {
    q: 'Is Amplifly free?',
    a: 'Yes. Amplifly is free to download and use. Creating an account (for cross-device sync) is also free. There is no subscription.',
  },
  {
    q: 'Does it work offline?',
    a: 'Fully. All data lives on your device in local storage. You can use every feature — brain check-ins, conditions, flow logging, the recommender, the manual — without a network connection.',
  },
  {
    q: 'How does the recommendation engine actually work?',
    a: 'It\'s a Thompson-sampling contextual bandit. Each condition is an "arm" keyed by your ND profile, brain state, and time of day. The bandit starts from research-cited priors for your profile and updates a Beta posterior every time you give feedback — thumbs up/down, or a high-intensity flow session logged within 2 hours. All computation runs on your device.',
  },
  {
    q: 'What neurodivergent profiles does it support?',
    a: 'ADHD, Autism, AuDHD, Dyslexia, Dyscalculia, Dyspraxia/DCD, Tourette\'s, Sensory Processing, OCD, Anxiety, Depression, PTSD/C-PTSD, Bipolar, Twice Exceptional (2e), and Other. You can select multiple — the recommender handles them as a combined profile.',
  },
  {
    q: 'What is the flow forecast?',
    a: 'A small neural network trained on synthetic data built from published research on focus and neurodivergence. The weights are fixed. A personal calibration layer blends those predictions with your own logged session data as you build history.',
  },
  {
    q: 'Is my data private?',
    a: 'Yes. Everything is on your device by default. If you create an account for sync, your data is encrypted in transit and stored on Supabase\'s servers solely for backup — it is never sold, shared, or used for advertising. We collect no analytics or crash reports.',
  },
  {
    q: 'What platforms is it on?',
    a: 'iOS and Android. Built in React Native with Expo, so it runs natively on both.',
  },
  {
    q: 'Can Amplifly replace therapy or medical support?',
    a: 'No. Amplifly is a self-understanding and focus tool, not a clinical product. If you need mental health support, please work with a qualified professional.',
  },
];
---
<section id="faq" class="bg-soft-blue py-24">
  <div class="container px-6 mx-auto max-w-3xl">

    <div class="text-center mb-16">
      <p class="text-bright-blue text-sm font-semibold tracking-widest uppercase mb-4">Questions</p>
      <h2 class="text-deep-navy text-3xl md:text-4xl font-bold">Frequently asked</h2>
    </div>

    <div class="space-y-3">
      {faqs.map((faq, i) => (
        <div class="bg-white rounded-2xl overflow-hidden">
          <button
            class="faq-btn w-full text-left px-6 py-5 flex items-center justify-between gap-4"
            data-index={i}
            aria-expanded="false"
          >
            <span class="text-deep-navy font-semibold text-base">{faq.q}</span>
            <span class="faq-icon text-bright-blue flex-shrink-0 transition-transform duration-200 text-xl">+</span>
          </button>
          <div class="faq-answer hidden px-6 pb-5">
            <p class="text-accessible-gray text-base leading-relaxed">{faq.a}</p>
          </div>
        </div>
      ))}
    </div>

    <p class="text-center text-accessible-gray mt-10 text-sm">
      More questions? Email us at{' '}
      <a href="mailto:hello@amplifly.me" class="text-bright-blue hover:underline">hello@amplifly.me</a>
    </p>
  </div>
</section>

<script>
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const answer = btn.nextElementSibling as HTMLElement;
      const icon   = btn.querySelector('.faq-icon') as HTMLElement;
      const open   = !answer.classList.contains('hidden');
      answer.classList.toggle('hidden', open);
      icon.textContent   = open ? '+' : '−';
      btn.setAttribute('aria-expanded', String(!open));
    });
  });
</script>
