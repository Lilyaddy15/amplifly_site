---
---
<section class="bg-deep-navy min-h-screen flex items-center pt-16">
  <div class="container px-6 mx-auto py-24 lg:py-32">

    <div class="max-w-3xl">
      <p class="text-medium-blue text-sm font-semibold tracking-widest uppercase mb-6">
        A flow &amp; strengths tool for neurodivergent minds
      </p>

      <h1 class="text-white text-4xl md:text-6xl font-bold leading-tight tracking-tight mb-6">
        Your brain has five modes.<br/>
        <span class="text-bright-blue">Amplifly helps you<br/>work with all of them.</span>
      </h1>

      <p class="text-medium-blue text-lg md:text-xl leading-relaxed mb-10 max-w-2xl">
        Check in with how your brain feels today. Get matched techniques that work for
        that specific state. Log your sessions. Watch a personal operating manual build
        itself — all on your device, no subscription, no tracking.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 mb-16">
        <a href="/#waitlist"
           class="bg-bright-blue hover:bg-bright-blue/80 text-white font-semibold px-8 py-4 rounded-xl transition-colors text-center text-base">
          Get Early Access
        </a>
        <a href="/#how-it-works"
           class="border border-medium-blue/40 hover:border-medium-blue text-medium-blue hover:text-white font-semibold px-8 py-4 rounded-xl transition-colors text-center text-base">
          See How It Works
        </a>
      </div>

      <div class="flex flex-wrap gap-x-8 gap-y-3 text-sm text-medium-blue/70">
        <span class="flex items-center gap-2"><span class="text-green-400">✓</span> Fully offline by default</span>
        <span class="flex items-center gap-2"><span class="text-green-400">✓</span> No analytics or ad tracking</span>
        <span class="flex items-center gap-2"><span class="text-green-400">✓</span> Free to use</span>
        <span class="flex items-center gap-2"><span class="text-green-400">✓</span> iOS &amp; Android</span>
      </div>
    </div>

    <!-- Brain state cards -->
    <div class="mt-20 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3 max-w-3xl">
      {[
        { emoji: '🎯', label: 'Sharp',     desc: 'Clear and focused' },
        { emoji: '🌶️', label: 'Spicy',    desc: 'Energy is firing' },
        { emoji: '🪫', label: 'Flat',      desc: 'Low and neutral' },
        { emoji: '🌫️', label: 'Foggy',   desc: 'Heavy and slow' },
        { emoji: '🌪️', label: 'Scattered','desc': 'Overwhelmed' },
      ].map(s => (
        <div class="bg-white/5 border border-white/10 rounded-xl p-4 text-center">
          <div class="text-3xl mb-2">{s.emoji}</div>
          <div class="text-white font-semibold text-sm">{s.label}</div>
          <div class="text-medium-blue/60 text-xs mt-1">{s.desc}</div>
        </div>
      ))}
    </div>
    <p class="text-medium-blue/50 text-sm mt-4">Five brain states. Pick one each morning. No wrong answer.</p>
  </div>
</section>
