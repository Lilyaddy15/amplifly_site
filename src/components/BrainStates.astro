---
const states = [
  {
    emoji: '🎯',
    label: 'Sharp',
    description: 'Clear, focused, the world feels organized.',
    bestFor: ['Deep work', 'Hard problems', 'Writing', 'Big decisions'],
    protectFrom: ['Notifications', 'Context switches', 'Errands'],
  },
  {
    emoji: '🌶️',
    label: 'Spicy',
    description: 'Lots of energy, ideas firing, hard to sit still.',
    bestFor: ['Creative work', 'Brainstorming', 'Movement', 'Recording ideas'],
    protectFrom: ['Long meetings', 'Detail work needing precision'],
  },
  {
    emoji: '🪫',
    label: 'Flat',
    description: 'Low energy, neutral, nothing pulling you.',
    bestFor: ['Admin', 'Errands', 'Tidying', 'Low-stakes tasks'],
    protectFrom: ['Big decisions', 'Anything dopamine-dependent'],
  },
  {
    emoji: '🌫️',
    label: 'Foggy',
    description: 'Hard to think, words slow, body feels heavy.',
    bestFor: ['Rest', 'One tiny win', 'Hydration + food', 'Comfort routines'],
    protectFrom: ['Forcing productivity', 'Self-judgment'],
  },
  {
    emoji: '🌪️',
    label: 'Scattered',
    description: 'Overwhelmed, too many tabs open in your head.',
    bestFor: ['Grounding', 'One anchor task', 'Brain dump', 'Movement'],
    protectFrom: ['Adding more inputs', 'Long to-do lists'],
  },
];
---
<section id="brain-states" class="bg-deep-navy py-24">
  <div class="container px-6 mx-auto">

    <div class="max-w-2xl mb-16">
      <p class="text-medium-blue text-sm font-semibold tracking-widest uppercase mb-4">Five brain states</p>
      <h2 class="text-white text-3xl md:text-4xl font-bold mb-4">
        Most apps assume your brain works the same every day.
        <span class="text-bright-blue"> Amplifly starts with how it actually feels.</span>
      </h2>
      <p class="text-medium-blue text-lg leading-relaxed">
        Your brain state shapes everything — what kind of work you can do, which techniques will help,
        how to protect your energy. Knowing which state you're in is the whole game.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      {states.map(s => (
        <div class="bg-white/5 border border-white/10 rounded-2xl p-6 hover:bg-white/8 transition-colors">
          <div class="text-4xl mb-3">{s.emoji}</div>
          <h3 class="text-white font-bold text-xl mb-2">{s.label}</h3>
          <p class="text-medium-blue text-sm mb-4 leading-relaxed">{s.description}</p>

          <div class="space-y-3">
            <div>
              <p class="text-medium-blue/50 text-xs font-semibold uppercase tracking-wider mb-2">Best for</p>
              <div class="flex flex-wrap gap-2">
                {s.bestFor.map(item => (
                  <span class="bg-bright-blue/10 text-bright-blue text-xs px-2 py-1 rounded-md">{item}</span>
                ))}
              </div>
            </div>
            <div>
              <p class="text-medium-blue/50 text-xs font-semibold uppercase tracking-wider mb-2">Protect from</p>
              <div class="flex flex-wrap gap-2">
                {s.protectFrom.map(item => (
                  <span class="bg-white/5 text-medium-blue/70 text-xs px-2 py-1 rounded-md">{item}</span>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}

      <!-- Closing card -->
      <div class="bg-bright-blue/10 border border-bright-blue/20 rounded-2xl p-6 flex flex-col justify-center">
        <p class="text-white font-bold text-lg mb-3">Pick the right state, get the right tools.</p>
        <p class="text-medium-blue text-sm leading-relaxed mb-4">
          Every recommendation Amplifly makes is filtered through your brain state and the time of day.
          The more you check in, the sharper it gets.
        </p>
        <a href="/#waitlist" class="text-bright-blue text-sm font-semibold hover:text-white transition-colors">
          Get Early Access →
        </a>
      </div>
    </div>
  </div>
</section>
