---
const year = new Date().getFullYear();
---
<footer class="bg-deep-navy border-t border-white/10 py-16">
  <div class="container px-6 mx-auto">

    <div class="grid md:grid-cols-4 gap-10 mb-12">

      <!-- Brand -->
      <div class="md:col-span-2">
        <p class="text-white font-bold text-xl mb-3">Amplifly</p>
        <p class="text-medium-blue text-sm leading-relaxed max-w-xs mb-5">
          A flow and strengths tool for neurodivergent minds. Understand your patterns.
          Work with your brain. Build your manual.
        </p>
        <p class="text-medium-blue/50 text-xs">Fully offline by default. Free to use. No tracking.</p>
      </div>

      <!-- Links: Product -->
      <div>
        <p class="text-medium-blue text-xs font-semibold uppercase tracking-widest mb-4">Product</p>
        <ul class="space-y-3">
          <li><a href="/#brain-states" class="text-medium-blue/70 hover:text-white text-sm transition-colors">Brain States</a></li>
          <li><a href="/#conditions"   class="text-medium-blue/70 hover:text-white text-sm transition-colors">Conditions</a></li>
          <li><a href="/#manual"       class="text-medium-blue/70 hover:text-white text-sm transition-colors">Your Manual</a></li>
          <li><a href="/#privacy"      class="text-medium-blue/70 hover:text-white text-sm transition-colors">Privacy</a></li>
          <li><a href="/#faq"          class="text-medium-blue/70 hover:text-white text-sm transition-colors">FAQ</a></li>
        </ul>
      </div>

      <!-- Links: Company + Legal -->
      <div>
        <p class="text-medium-blue text-xs font-semibold uppercase tracking-widest mb-4">Company</p>
        <ul class="space-y-3 mb-6">
          <li><a href="/about"              class="text-medium-blue/70 hover:text-white text-sm transition-colors">About</a></li>
          <li><a href="mailto:hello@amplifly.me" class="text-medium-blue/70 hover:text-white text-sm transition-colors">Contact</a></li>
        </ul>
        <p class="text-medium-blue text-xs font-semibold uppercase tracking-widest mb-4">Legal</p>
        <ul class="space-y-3">
          <li><a href="/privacy-policy"    class="text-medium-blue/70 hover:text-white text-sm transition-colors">Privacy Policy</a></li>
          <li><a href="/terms-of-service"  class="text-medium-blue/70 hover:text-white text-sm transition-colors">Terms of Service</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/10 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-medium-blue/50 text-sm">© {year} Amplifly. All rights reserved.</p>
      <p class="text-medium-blue/50 text-sm">
        Questions? <a href="mailto:hello@amplifly.me" class="text-medium-blue hover:text-white transition-colors">hello@amplifly.me</a>
      </p>
    </div>
  </div>
</footer>
